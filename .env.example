AWS_PROFILE=your-sso-profile
AWS_REGION=us-east-1

# Use an inference profile ID or ARN, not a foundation model ID, when the
# selected model does not support on-demand throughput. For Claude Sonnet 4.6,
# this Global profile can be invoked from ap-northeast-1 and selected US Regions.
BEDROCK_INFERENCE_PROFILE_ID=global.anthropic.claude-sonnet-4-6
